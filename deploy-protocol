#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TSX_LOADER="$ROOT_DIR/scripts/node_modules/tsx/dist/loader.mjs"

if [[ ! -f "$TSX_LOADER" ]]; then
  echo "Missing scripts dependencies. Run: npm --prefix scripts install" >&2
  exit 1
fi

exec node --import "$TSX_LOADER" "$ROOT_DIR/scripts/deploy-protocol.ts" "$@"
