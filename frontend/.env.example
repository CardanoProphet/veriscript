# Backend API base URL
VITE_API_URL=http://localhost:3001

# Blockfrost project ID (used by MeshSDK for TX building & fee estimation)
VITE_BLOCKFROST_API_KEY=preprodYourKeyHere

# Target network: preprod | mainnet
VITE_CARDANO_NETWORK=preprod

# Optional override for the Protocol Parameters reference UTxO.
# If unset, frontend/src/generated/protocolDeployment.ts is used.
VITE_PROTOCOL_PARAMS_TX_HASH=
VITE_PROTOCOL_PARAMS_TX_IX=0
